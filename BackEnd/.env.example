# =========================================================================
#  ATMLog - Variaveis de ambiente (copie para ".env" e preencha)
# =========================================================================

# ---- PocketBase (banco) ----
PB_URL=http://127.0.0.1:8090
PB_ADMIN_EMAIL=admin@atmlog.local
PB_ADMIN_PASSWORD=TROQUE_ESTA_SENHA_FORTE

# ---- JWT (autenticacao da API) ----
JWT_SECRET=defina_um_segredo_grande_e_aleatorio
JWT_REFRESH_SECRET=defina_outro_segredo_grande_e_aleatorio

# ---- Portas ----
PORT_API=3001
PORT_CLIENT=8080
PORT_ADMIN=8082

# ---- Google (Sheets sync + Drive upload) ----
