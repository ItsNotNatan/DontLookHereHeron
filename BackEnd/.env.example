# =========================================================================
#  ATMLog - Variaveis de ambiente (modelo).
#  Na 1a execucao o auto-deploy CRIA o .env a partir deste arquivo,
#  PERGUNTA o e-mail/senha do admin do banco no terminal e gera os
#  segredos JWT automaticamente. Nada disso vai pro GitHub (.env e ignorado).
# =========================================================================

# ---- PocketBase (banco) ----
PB_URL=http://127.0.0.1:8091
# Deixe vazios: o auto-deploy pergunta no terminal na 1a vez.
PB_ADMIN_EMAIL=
PB_ADMIN_PASSWORD=

# ---- JWT (gerados automaticamente na 1a vez) ----
JWT_SECRET=
JWT_REFRESH_SECRET=

# ---- Portas ----
PORT_API=3001
PORT_CLIENT=8080
PORT_ADMIN=8082

# ---- Google (opcional: Sheets sync + Drive upload) ----
# Deixe GOOGLE_CLIENT_EMAIL vazio para DESATIVAR a sincronizacao do Sheets.
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_ID=1xacIwga7a_Qe5Z9YG5S6KqfHHwRLGUg9OJO9CD0FthU
DRIVE_FOLDER_ID=
